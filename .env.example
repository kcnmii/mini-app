# ═══════════════════════════════════════════════════════
# Environment variables for doc-mini-app
# Copy this file as .env and fill in your values
# ═══════════════════════════════════════════════════════

# ── Domain Settings ──
VITE_API_BASE_URL=https://api.doc.onlink.kz
FRONTEND_ORIGIN=https://doc.onlink.kz
TELEGRAM_APP_URL=https://doc.onlink.kz

# ── Telegram Bot ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=docminiapp_bot
TELEGRAM_TEST_CHAT_ID=

# ── Internal Services (Docker network) ──
DOCGEN_URL=http://docgen:4001
SERVICE_URL_GOTENBERG=http://gotenberg:3000
SERVICE_USER_GOTENBERG=
SERVICE_PASSWORD_GOTENBERG=

# ── SQLite (inside container volume) ──
SQLITE_PATH=/app/data/docmini.sqlite3

# ── Security ──
JWT_SECRET=CHANGE_ME_TO_RANDOM_STRING

# ── Optional ──
OPENAI_API_KEY=
